# .env — Configuration du greffon KeyPass
# Copier ce fichier en .env et remplir les valeurs

# URL de l'API KeyPass (ne pas modifier sauf si backend custom)
KEYPASS_API_URL=https://www.keypasshotel.com

# Clé API hôtel — fournie par KeyPass lors de la signature du contrat
# Doit correspondre à HOTEL_API_KEY dans les variables d'environnement Vercel
# Exemple : kp_hotel_a3f82c1d9e4b7f2a
HOTEL_API_KEY=
