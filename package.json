{
  "name": "keypass-plugin",
  "version": "1.0.0",
  "description": "Greffon KeyPass — Overlay Electron sur les logiciels de serrures hôtelières",
  "main": "main.js",
  "scripts": {
    "start":   "electron .",
    "dev":     "electron . --dev",
    "build":   "electron-builder --win --x64",
    "install-service": "node installer/setup.js"
  },
  "dependencies": {
    "axios":        "^1.7.2",
    "electron-log": "^5.1.2",
    "node-windows":  "^1.0.0-beta.8"
  },
  "devDependencies": {
    "electron":         "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId":       "com.keypass.plugin",
    "productName": "KeyPass Plugin",
    "win": {
      "target": "nsis",
      "icon":   "ui/icon.ico"
    },
    "nsis": {
      "oneClick":          false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "runAfterFinish":    true
    }
  }
}
